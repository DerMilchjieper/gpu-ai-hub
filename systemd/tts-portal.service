[Unit]
Description=Zen Voice Piper TTS Portal
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/wizzard
ExecStart=/home/wizzard/whisper-env/bin/uvicorn tts_portal:app --host 0.0.0.0 --port 8002
Restart=always
RestartSec=2
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
