[Unit]
Description=Zen Docs Portal (RAG)
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/wizzard/gpu-ai-hub/src
ExecStart=/home/wizzard/ai/docs/venv/bin/uvicorn docs_portal:app --host 0.0.0.0 --port 8004
